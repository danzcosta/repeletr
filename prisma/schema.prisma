datasource db {
  provider = "postgresql"
  
}

generator client {
  provider = "prisma-client-js"
}

model SubmissaoFatura {
  id          String   @id @default(uuid())
  nome        String
  email       String
  telefone    String?
  faturaPath  String
  criadoEm    DateTime @default(now())
faturaGasPath String?  // A de gás (Opcional)

  @@map("submissoes_faturas")
}